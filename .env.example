# OllamaStudio — Configuration
# Copiez ce fichier en .env et adaptez les valeurs

# URL de votre serveur Ollama
# Local : http://localhost:11434
# Réseau local : http://192.168.1.100:11434
# Via Docker : http://host.docker.internal:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Mode API Ollama : "openai" (défaut) ou "anthropic" (Ollama v0.14.0+)
# Le mode anthropic permet d'utiliser Claude Code avec des modèles locaux
OLLAMA_API_MODE=openai

# Modèle par défaut au démarrage
OLLAMA_DEFAULT_MODEL=qwen3-coder

# CORS — domaines autorisés à accéder au backend
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Timeout maximum pour les requêtes Ollama (secondes)
OLLAMA_TIMEOUT=300

# Timeout d'exécution des commandes shell (secondes)
SHELL_TIMEOUT=30

# Taille maximale d'un fichier lu/écrit (octets) — 10 Mo par défaut
MAX_FILE_SIZE=10485760
